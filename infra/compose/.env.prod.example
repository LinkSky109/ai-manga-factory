APP_ENV=production
API_PORT=8000
WEB_PORT=5173

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ai_manga_factory
REDIS_URL=redis://redis:6379/0

POSTGRES_DB=ai_manga_factory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
PUBLIC_HTTP_PORT=8080

# Optional: override named volumes with host bind mounts when your Docker runtime
# can write to the target paths. Defaults keep production compose portable.
# APP_DATA_MOUNT=/absolute/path/to/data
# APP_SECRETS_MOUNT=/absolute/path/to/secrets

AUTH_ENABLED=true
AUTH_BOOTSTRAP_ADMIN_TOKEN=change-me
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@ai-manga-factory.local
AUTH_BOOTSTRAP_ADMIN_NAME=Factory Admin

ARCHIVE_TARGETS=local-archive,object-storage
OBJECT_STORAGE_MODE=mirror
OBJECT_STORAGE_BUCKET=ai-manga-factory
DEFAULT_ROUTING_MODE=smart

PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_ANONYMOUS_ENABLED=false
