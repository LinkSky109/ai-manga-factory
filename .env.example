APP_ENV=development
APP_NAME=ai-manga-factory

API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=5173

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_manga_factory
REDIS_URL=redis://localhost:6379/0

ARTIFACT_ROOT=./data/runtime/artifacts
ARCHIVE_ROOT=./data/archives
ARCHIVE_TARGETS=local-archive,object-storage
OBJECT_STORAGE_MODE=mirror
ARCHIVE_INDEX_PATH=./data/archives/index/artifact-manifest.json
ARCHIVE_SYNC_MAX_ATTEMPTS=3
PREVIEW_ROOT=./data/runtime/previews
OBJECT_STORAGE_ROOT=./data/archives/object-storage
OBJECT_STORAGE_BUCKET=ai-manga-factory
OBJECT_STORAGE_PUBLIC_BASE_URL=
QUARK_PAN_MIRROR_ROOT=./data/archives/quark-pan
QUARK_PAN_MODE=mirror
QUARK_PAN_CONFIG_DIR=./secrets/quark_pan
QUARK_PAN_COOKIE_FILE=./secrets/quark_pan_cookie.txt
QUARK_PAN_ROOT_FOLDER=AI-Manga-Factory
QUARK_PAN_REPLACE_EXISTING=true
ALIYUNDRIVE_MIRROR_ROOT=./data/archives/aliyundrive
ALIYUNDRIVE_MODE=mirror
ALIYUNDRIVE_CONFIG_DIR=./secrets/aliyundrive
ALIYUNDRIVE_NAME=ai-manga-factory
ALIYUNDRIVE_ROOT_FOLDER=AI-Manga-Factory
ALIYUNDRIVE_CHECK_NAME_MODE=overwrite

DEFAULT_ROUTING_MODE=smart
DEFAULT_IMAGE_PROVIDER=kling
DEFAULT_VIDEO_PROVIDER=vidu
DEFAULT_VOICE_PROVIDER=voice_clone
AUTH_ENABLED=false
AUTH_BOOTSTRAP_ADMIN_TOKEN=
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@ai-manga-factory.local
AUTH_BOOTSTRAP_ADMIN_NAME=Factory Admin
AUTH_BOOTSTRAP_OPERATOR_TOKEN=
AUTH_BOOTSTRAP_OPERATOR_EMAIL=operator@ai-manga-factory.local
AUTH_BOOTSTRAP_OPERATOR_NAME=Pipeline Operator
AUTH_BOOTSTRAP_REVIEWER_TOKEN=
AUTH_BOOTSTRAP_REVIEWER_EMAIL=reviewer@ai-manga-factory.local
AUTH_BOOTSTRAP_REVIEWER_NAME=Review Lead
AUTH_BOOTSTRAP_VIEWER_TOKEN=
AUTH_BOOTSTRAP_VIEWER_EMAIL=viewer@ai-manga-factory.local
AUTH_BOOTSTRAP_VIEWER_NAME=Observer

S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

ARK_API_KEY=
ARK_BASE_URL=
ARK_TEXT_MODEL=Doubao-Seed-1.6
ARK_IMAGE_MODEL=Doubao-Seedream-4.5
ARK_VIDEO_MODEL=Doubao-Seedance-1.5-pro

AI_MANGA_FACTORY_QUARK_COOKIE=

PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
WORKER_STALE_AFTER_SECONDS=30
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS_ENABLED=true
VITE_API_TOKEN=
