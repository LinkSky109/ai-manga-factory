# Server bind
AI_MANGA_FACTORY_HOST=0.0.0.0
AI_MANGA_FACTORY_PORT=8000

# Runtime storage
AI_MANGA_FACTORY_RUNTIME_DIR=/var/lib/ai-manga-factory/runtime
AI_MANGA_FACTORY_RUNTIME_STORAGE_CONFIG=/app/secrets/runtime_storage_config.json

# Model provider
ARK_API_KEY=
VOLC_ARK_API_KEY=

# Optional object storage sync
AI_MANGA_FACTORY_OSS_ACCESS_KEY_ID=
AI_MANGA_FACTORY_OSS_ACCESS_KEY_SECRET=
